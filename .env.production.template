# ========================================
# Odos AI — 生产环境变量模板
# 复制为 .env.production 并填入实际值
# ========================================

# 生图 — FLUX.2 (Black Forest Labs)，当前生效
# key 从 https://api.bfl.ai 获取。provider 可换：改 IMAGE_BASE_URL / IMAGE_MODEL，无需改代码
IMAGE_API_KEY=
IMAGE_BASE_URL=https://api.bfl.ai
IMAGE_MODEL=flux-2-klein-9b-preview

# Kling AI (旧生图通道，已弃用；保留备用)
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
KELING_BASE_URL=https://api-beijing.klingai.com
KLING_IMAGE_MODEL=kling-image-o1

# MiniMax (TTS 语音合成)
MINIMAX_API_KEY=

# LLM — GLM-5.2 (智谱 / Zhipu 国内站，OpenAI 兼容)
# key 从 https://open.bigmodel.cn 控制台获取。provider 可换：改 LLM_BASE_URL / LLM_MODEL_* 即可，无需改代码
LLM_API_KEY=
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_MODEL_PRO=glm-5.2
LLM_MODEL_FLASH=glm-5.2
# GLM-5.2 是推理模型；默认关闭思考（更快/更省）。设为 enabled 可开启
LLM_THINKING=disabled

# OpenRouter (旧 LLM 通道，已弃用；保留备用)
OPENROUTER_API_KEY=

# 阿里云 OSS (音频存储)
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=odosai
OSS_REGION=oss-cn-beijing
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com

# Supabase (数据库 + 认证)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
DATABASE_URL=
