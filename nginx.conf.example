# Odos AI — Nginx 配置参考
# 复制到 /etc/nginx/sites-available/odos-ai
# 然后 ln -s /etc/nginx/sites-available/odos-ai /etc/nginx/sites-enabled/
# 修改 odosai.top 为实际域名

# HTTP → HTTPS 重定向
server {
    listen 80;
    server_name odosai.top www.odosai.top;
    return 301 https://$host$request_uri;
}

# HTTPS 主配置
server {
    listen 443 ssl http2;
    server_name odosai.top www.odosai.top;

    # SSL 证书 (certbot 自动生成)
    ssl_certificate /etc/letsencrypt/live/odosai.top/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/odosai.top/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;

    # 反向代理到 Next.js
    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;

        # SSE 支持 (LLM streaming)
        proxy_buffering off;
        proxy_read_timeout 300s;
    }

    # Next.js 静态资源长缓存
    location /_next/static {
        proxy_pass http://127.0.0.1:3000;
        expires 365d;
        add_header Cache-Control "public, immutable";
    }

    # 公共静态资源
    location /public {
        proxy_pass http://127.0.0.1:3000;
        expires 30d;
        add_header Cache-Control "public";
    }

    # 请求体大小限制 (图片/音频上传)
    client_max_body_size 50M;
}
